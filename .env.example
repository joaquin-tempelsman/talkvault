# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OpenAI (Whisper + GPT-4o)
OPENAI_API_KEY=your_openai_api_key_here

# Vault
VAULT_REPO_PATH=/opt/talkvault/vault
VAULT_GITHUB_REPO=git@github-vault:YOUR_GITHUB_USER/YOUR_VAULT_REPO.git

# Flow config: "ask" or "guess" per step
FLOW_DETECT_NOTE_GROUP=guess
FLOW_DETECT_ENTITIES=ask

# Session timeout in seconds (default: 600 = 10 minutes)
SESSION_TIMEOUT=600

# Optional
LOG_LEVEL=INFO
